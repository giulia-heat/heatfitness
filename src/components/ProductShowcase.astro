---
const BASE = "https://cdn.prod.website-files.com/695a3cceefe59f7b8ee1f77a";

const MOCKUP      = `${BASE}/69805c9aeca506a252dc7c90_Frame%20427319328.png`;
const MOCKUP_500  = `${BASE}/69805c9aeca506a252dc7c90_Frame%20427319328-p-500.png`;
const MOCKUP_800  = `${BASE}/69805c9aeca506a252dc7c90_Frame%20427319328-p-800.png`;
const MOCKUP_1080 = `${BASE}/69805c9aeca506a252dc7c90_Frame%20427319328-p-1080.png`;
const MOCKUP_1600 = `${BASE}/69805c9aeca506a252dc7c90_Frame%20427319328-p-1600.png`;
---

<section class="showcase" id="app" aria-label="App HEAT">
  <div class="showcase__inner">

    <div class="showcase__header" data-animate>
      <p class="showcase__eyebrow">L'app</p>
      <h2 class="showcase__title">
        Allenamenti già programmati.<br />Zero improvvisazione.
      </h2>
      <p class="showcase__sub">
        Segui un percorso strutturato con progressioni settimanali, calendario integrato e monitoraggio dei progressi.
      </p>
    </div>

    <div class="showcase__mockup" data-animate>
      <img
        src={MOCKUP_800}
        srcset={`${MOCKUP_500} 500w, ${MOCKUP_800} 800w, ${MOCKUP_1080} 1080w, ${MOCKUP_1600} 1600w`}
        sizes="(max-width: 640px) calc(100vw - 48px), (max-width: 960px) calc(100vw - 48px), 900px"
        alt="App HEAT su smartphone — calendario, allenamenti e ricette"
        class="showcase__img"
        width="1600"
        height="900"
        loading="lazy"
        decoding="async"
      />
    </div>

    <p class="showcase__caption">Disponibile su iOS e Android</p>

  </div>
</section>

<style>
  .showcase {
    background: #ffffff;
    padding: 96px 24px;
  }

  .showcase__inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 56px;
  }

  .showcase__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    max-width: 820px;
  }

  .showcase__eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .showcase__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--white);
  }

  .showcase__sub {
    font-size: 17px;
    color: var(--gray-500);
    line-height: 1.7;
    max-width: 520px;
  }

  .showcase__mockup {
    width: 100%;
    max-width: 900px;
  }

  .showcase__img {
    width: 100%;
    height: auto;
    display: block;
    /* drop shadow leggero per far risaltare i telefoni sul bianco */
    filter: drop-shadow(0 24px 64px rgba(0, 0, 0, 0.12));
  }

  .showcase__caption {
    font-size: 13px;
    color: var(--gray-400);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 500;
  }
</style>
