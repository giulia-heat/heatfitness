---
const YT_ID = "nmDXTVFalzM";
---

<section class="testimonial-video">
  <div class="container">

    <div class="tv__inner" data-animate>

      <!-- Citazione — sinistra su desktop, sopra su mobile -->
      <blockquote class="tv__quote">
        <span class="tv__quote-mark">"</span>
        Non cercavo un allenamento.<br />Cercavo un metodo e una community.
        <span class="tv__quote-mark">"</span>
      </blockquote>

      <!-- Video + tagline + CTA -->
      <div class="tv__right">
        <div class="tv__video-wrap">
          <iframe
            src={`https://www.youtube.com/embed/${YT_ID}?rel=0&modestbranding=1`}
            title="Testimonianza utente HEAT Fitness"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            class="tv__iframe"
          ></iframe>
        </div>
        <p class="tv__tagline">Metodo. Costanza. Community.</p>
        <a href="https://web.cottoaldente.it/" target="_blank" rel="noopener" class="tv__cta">Inizia ora</a>
      </div>

    </div>

  </div>
</section>

<style>
  .testimonial-video {
    background: #f5f2ee;
    padding: var(--section-py) 0;
  }

  /* Desktop: affiancati */
  .tv__inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 64px;
    max-width: 960px;
    margin: 0 auto;
  }

  .tv__quote {
    flex: 1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 3.5vw, 40px);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 0;
    text-align: left;
  }

  .tv__quote-mark {
    color: var(--orange);
  }

  .tv__right {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    width: 320px;
  }

  .tv__video-wrap {
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.15);
  }

  .tv__iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .tv__tagline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--orange);
    text-align: center;
  }

  .tv__cta {
    display: inline-flex;
    align-items: center;
    height: 48px;
    padding: 0 32px;
    background: #111111;
    color: #ffffff;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition);
  }

  .tv__cta:hover {
    background: var(--orange);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(232, 82, 26, 0.3);
  }

  /* Mobile: uno sopra l'altro */
  @media (max-width: 768px) {
    .testimonial-video {
      padding: 56px 0;
    }

    .tv__inner {
      flex-direction: column;
      align-items: center;
      gap: 28px;
    }

    .tv__quote {
      text-align: center;
    }

    .tv__right {
      width: 100%;
      max-width: 340px;
    }
  }
</style>
