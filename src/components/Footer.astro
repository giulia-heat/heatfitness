---
const BASE = "https://cdn.prod.website-files.com/695a3cceefe59f7b8ee1f77a";
const LOGO = `${BASE}/6973a72cebbbf19eca3d5d06_LOGO%20heat.svg`;
---

<!-- CTA Section -->
<section class="cta" aria-labelledby="cta-title">
  <div class="container">
    <div class="cta__inner" data-animate>
      <div class="cta__bg" aria-hidden="true"></div>
      <h2 class="cta__title" id="cta-title">
        Inizia oggi.<br />
        Al resto pensa HEAT.
      </h2>
      <p class="cta__text">
        Allenamenti già programmati, progressioni guidate e un metodo che evolve con te.<br />
        Tu devi solo iniziare.
      </p>
      <a href="https://web.cottoaldente.it/" target="_blank" rel="noopener" class="btn btn-primary cta__btn">
        Inizia con HEAT
      </a>
      <p class="cta__note">
        Prezzo bloccato a €99,99 per i primi 500 abbonati. Non aumenterà ai rinnovi.
      </p>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer" role="contentinfo">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="HEAT Fitness">
        <img src={LOGO} alt="HEAT Fitness" width="72" height="24" loading="lazy" />
      </a>
      <p class="footer__tagline">Il Tuo Percorso Fitness.</p>
    </div>

    <nav class="footer__nav" aria-label="Link footer">
      <ul role="list">
        <li><a href="/privacy" class="footer__link">Privacy</a></li>
        <li><a href="/termini" class="footer__link">Termini e condizioni</a></li>
        <li><a href="https://cottoaldente.it/" rel="noopener" target="_blank" class="footer__link">Cotto al Dente</a></li>
      </ul>
    </nav>
  </div>

  <div class="container footer__bottom">
    <p class="footer__copy">
      &copy; {new Date().getFullYear()} HEAT Fitness. Tutti i diritti riservati.
    </p>
  </div>
</footer>

<style>
  /* ============================================
     CTA Section
     ============================================ */
  .cta {
    padding: var(--section-py) 0;
  }

  .cta__inner {
    background: var(--gray-100);
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: var(--radius-xl);
    padding: 80px 64px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    position: relative;
    overflow: hidden;
  }

  .cta__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 120%, rgba(232, 82, 26, 0.14) 0%, transparent 60%);
    pointer-events: none;
  }

  .cta__title {
    font-size: clamp(40px, 6vw, 80px);
    color: var(--white);
    position: relative;
    z-index: 1;
    line-height: 1.05;
  }

  .cta__text {
    font-size: 17px;
    color: var(--gray-500);
    line-height: 1.75;
    max-width: 420px;
    position: relative;
    z-index: 1;
  }

  .cta__btn {
    padding: 16px 40px;
    font-size: 16px;
    position: relative;
    z-index: 1;
  }

  .cta__note {
    font-size: 13px;
    color: var(--gray-400);
    position: relative;
    z-index: 1;
    margin-top: -8px;
  }

  /* ============================================
     Footer
     ============================================ */
  .footer {
    border-top: 1px solid rgba(17, 17, 17, 0.08);
    padding: 40px 0 32px;
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .footer__logo img {
    height: 24px;
    width: auto;
  }

  .footer__tagline {
    font-size: 12px;
    color: var(--gray-500);
    letter-spacing: 0.05em;
  }

  .footer__nav ul {
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .footer__link {
    font-size: 13px;
    color: var(--gray-500);
    transition: color var(--transition);
    letter-spacing: 0.03em;
  }

  .footer__link:hover {
    color: var(--white);
  }

  .footer__bottom {
    padding-top: 24px;
    border-top: 1px solid rgba(17, 17, 17, 0.06);
  }

  .footer__copy {
    font-size: 12px;
    color: var(--gray-400);
  }

  @media (max-width: 640px) {
    .cta__inner {
      padding: 48px 28px;
    }

    .footer__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
