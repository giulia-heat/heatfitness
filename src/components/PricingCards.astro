---
const featuresAnnual = [
  "Accesso completo",
  "Risparmi il 33%",
  "Prezzo bloccato per sempre",
];

const featuresMonthly = [
  "Accesso completo",
  "Paghi mese per mese",
  "Annulli quando vuoi",
];

const guarantees = ["Cancella quando vuoi", "Nessun vincolo", "Supporto incluso"];
---

<section class="pc" id="pricing" aria-labelledby="pricing-title">
  <div class="container">

    <!-- Header -->
    <div class="pc__header" data-animate>
      <p class="pc__eyebrow">Prezzi</p>
      <h2 class="pc__title" id="pricing-title">Semplici. Senza vincoli.</h2>
      <p class="pc__sub">Un unico abbonamento per accedere a tutto. Nessun costo nascosto.</p>
    </div>

    <!-- Cards grid -->
    <div class="pc__grid">

      <!-- Piano Annuale (mostrato per primo) -->
      <article class="pc__card pc__card--featured" aria-label="Piano annuale HEAT — consigliato">

        <!-- Badge superiore fuori dal bordo -->
        <div class="pc__recommended-badge" aria-label="Piano consigliato">
          Solo per i primi 500 iscritti
        </div>

        <div class="pc__card-header">
          <div class="pc__plan-name-row">
            <h3 class="pc__plan-name">Piano Annuale</h3>
            <span class="pc__discount-badge">−33%</span>
          </div>
          <p class="pc__plan-sub">La scelta di chi vuole continuità</p>
        </div>

        <div class="pc__price-block">
          <p class="pc__original-price">€149,99/anno</p>
          <div class="pc__price">
            <span class="pc__currency">€</span>
            <span class="pc__amount">99,99</span>
          </div>
          <p class="pc__forever">Per sempre</p>
          <p class="pc__price-note">Prezzo bloccato ai rinnovi.<br />Non aumenterà mai.</p>
        </div>

        <ul class="pc__features" role="list">
          {featuresAnnual.map((f) => (
            <li class="pc__feature">
              <svg class="pc__check" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <circle cx="9" cy="9" r="9" fill="rgba(232,82,26,0.12)" />
                <path d="M5 9l3 3 5-5" stroke="#e8521a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {f}
            </li>
          ))}
        </ul>

        <a href="https://web.cottoaldente.it/?_gl=1*1rigkb2*_gcl_au*OTgxMjEwNTI2LjE3NjM3MTUwODk.#/signup" target="_blank" rel="noopener" class="pc__btn pc__btn--primary">
          Inizia ora
        </a>
      </article>

      <!-- Piano Mensile -->
      <article class="pc__card pc__card--base" aria-label="Piano mensile HEAT">
        <div class="pc__card-header">
          <h3 class="pc__plan-name">Piano Mensile</h3>
          <p class="pc__plan-sub">Inizia senza impegni</p>
        </div>

        <div class="pc__price-block">
          <div class="pc__price">
            <span class="pc__currency">€</span>
            <span class="pc__amount">24,99</span>
          </div>
          <p class="pc__period">/mese · fatturato mensilmente</p>
        </div>

        <ul class="pc__features" role="list">
          {featuresMonthly.map((f) => (
            <li class="pc__feature">
              <svg class="pc__check" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <circle cx="9" cy="9" r="9" fill="rgba(232,82,26,0.12)" />
                <path d="M5 9l3 3 5-5" stroke="#e8521a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {f}
            </li>
          ))}
        </ul>

        <a href="https://web.cottoaldente.it/?_gl=1*1rigkb2*_gcl_au*OTgxMjEwNTI2LjE3NjM3MTUwODk.#/signup" target="_blank" rel="noopener" class="pc__btn pc__btn--outline">
          Inizia ora
        </a>
        <p class="pc__btn-note">Attivi oggi. Accedi subito.</p>
      </article>

    </div>

    <!-- Garanzie -->
    <div class="pc__guarantees">
      {guarantees.map((g) => (
        <span class="pc__guarantee">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#e8521a" stroke-width="2.5" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          {g}
        </span>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Layout sezione ── */
  .pc {
    background: #f5f2ee;
    padding: var(--section-py) 0;
  }

  /* ── Header ── */
  .pc__header {
    text-align: center;
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .pc__eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .pc__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5vw, 64px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--white);
    margin: 0;
  }

  .pc__sub {
    font-size: 16px;
    color: var(--gray-500);
    line-height: 1.7;
    max-width: 380px;
  }

  /* ── Grid — due colonne, allineate in alto ── */
  .pc__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    align-items: start;
    /* Lascia spazio in alto per il badge della card featured
       che sporge fuori dal bordo superiore */
    padding-top: 20px;
  }

  /* ── Card base ── */
  .pc__card {
    background: #ffffff;
    border: 1px solid rgba(17, 17, 17, 0.1);
    border-radius: 28px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Card featured (annuale) ── */
  .pc__card--featured {
    border: 2px solid var(--orange);
    background: linear-gradient(150deg, rgba(232, 82, 26, 0.06) 0%, #ffffff 55%);
    position: relative;
    /* Spazio interno in cima per accogliere il badge */
    padding-top: 44px;
  }

  /* ── Badge "Più conveniente" posizionato sopra il bordo della card ── */
  .pc__recommended-badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--orange);
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 20px 8px;
    border-radius: 0 0 14px 14px;
    white-space: nowrap;
  }

  /* ── Intestazione card ── */
  .pc__card-header {
    margin-bottom: 24px;
  }

  .pc__plan-name-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .pc__plan-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: var(--white);
    margin: 0;
  }

  .pc__plan-sub {
    font-size: 13px;
    color: var(--gray-500);
    margin-top: 4px;
  }

  .pc__discount-badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    background: rgba(232, 82, 26, 0.1);
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--orange);
  }

  /* ── Blocco prezzo ── */
  .pc__price-block {
    margin-bottom: 28px;
  }

  .pc__original-price {
    font-size: 13px;
    color: var(--gray-400);
    text-decoration: line-through;
    margin-bottom: 2px;
  }

  .pc__price {
    display: flex;
    align-items: baseline;
    gap: 2px;
    line-height: 1;
  }

  .pc__currency {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--white);
  }

  .pc__amount {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 56px;
    line-height: 1;
    color: var(--white);
  }

  .pc__period {
    font-size: 12px;
    color: var(--gray-400);
    margin-top: 4px;
  }

  .pc__forever {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--orange);
    margin-top: 4px;
  }

  .pc__btn-note {
    text-align: center;
    font-size: 12px;
    color: var(--gray-400);
    margin-top: 10px;
  }

  .pc__price-note {
    font-size: 12px;
    color: var(--gray-500);
    line-height: 1.6;
    margin-top: 10px;
    padding: 10px 12px;
    background: rgba(232, 82, 26, 0.06);
    border-left: 2px solid var(--orange);
    border-radius: 0 6px 6px 0;
  }

  /* ── Lista feature ── */
  .pc__features {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .pc__feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    color: var(--gray-600);
    line-height: 1.5;
  }

  .pc__check {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ── Bottoni ── */
  .pc__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition);
    cursor: pointer;
  }

  .pc__btn--outline {
    border: 1px solid rgba(17, 17, 17, 0.2);
    color: var(--white);
    background: transparent;
  }

  .pc__btn--outline:hover {
    background: rgba(17, 17, 17, 0.05);
  }

  .pc__btn--primary {
    background: var(--orange);
    color: #ffffff;
    border: none;
    box-shadow: 0 8px 24px rgba(232, 82, 26, 0.3);
  }

  .pc__btn--primary:hover {
    background: var(--orange-dark);
    transform: translateY(-1px);
    box-shadow: 0 12px 32px rgba(232, 82, 26, 0.4);
  }

  /* ── Garanzie ── */
  .pc__guarantees {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-top: 32px;
  }

  .pc__guarantee {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--gray-500);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .pc__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
