---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import PricingCards from '../components/PricingCards.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="HEAT – Il Tuo Percorso Fitness"
  description="Un percorso guidato di allenamento che evolve mentre ti alleni. Progressioni settimanali, live workout, ricette e piani personalizzati. Inizia oggi."
>
  <Header />

  <main id="main-content">
    <!-- Above the fold: nessun content-visibility -->
    <Hero />
    <SocialProof />

    <!-- Below the fold: content-visibility: auto per rendering differito -->
    <div class="cv-auto">
      <ProductShowcase />
    </div>
    <div class="cv-auto">
      <PricingCards />
    </div>
    <div class="cv-auto">
      <HowItWorks />
    </div>
    <div class="cv-auto">
      <Testimonials />
    </div>
    <div class="cv-auto">
      <FAQ />
    </div>
  </main>

  <Footer />
</Layout>

<!-- Intersection Observer per animazioni scroll -->
<script>
  const animateElements = document.querySelectorAll<HTMLElement>('[data-animate]');

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.1,
        rootMargin: '0px 0px -60px 0px',
      }
    );

    animateElements.forEach((el) => observer.observe(el));
  } else {
    animateElements.forEach((el) => el.classList.add('is-visible'));
  }
</script>
