---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { posts } from '../../data/posts';

export function getStaticPaths() {
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = posts.find((p) => p.slug === slug);
if (!post) return Astro.redirect('/blog');

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
}

const otherPosts = posts.filter((p) => p.slug !== slug).slice(0, 2);
---

<Layout
  title={`${post.title} – HEAT Blog`}
  description={post.excerpt}
  image={post.cover}
  canonical={`https://www.heatfitness.app/blog/${post.slug}`}
>
  <Header />

  <main>

    <!-- Hero articolo — stesso linguaggio del Hero della home -->
    <div class="ph__hero">
      <picture>
        <img
          src={post.cover}
          alt={post.title}
          class="ph__cover"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          width="1200"
          height="600"
        />
      </picture>
      <div class="ph__overlay"></div>
      <div class="ph__hero-content">
        <div class="container">
          <div class="ph__meta">
            <a href="/blog" class="ph__back">← Blog</a>
            <span class="ph__category">{post.category}</span>
          </div>
          <h1 class="ph__title">{post.title}</h1>
          <div class="ph__info">
            <time datetime={post.date}>{formatDate(post.date)}</time>
            <span aria-hidden="true">·</span>
            <span>{post.readTime} di lettura</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Corpo articolo -->
    <section class="ph__body-section">
      <div class="container">
        <div class="ph__layout">

          <!-- Testo -->
          <article class="ph__content" set:html={post.content} />

          <!-- Sidebar sticky — stesso stile card della home -->
          <aside class="ph__sidebar">
            <div class="ph__cta-card">
              <p class="ph__cta-eyebrow">Il metodo HEAT</p>
              <h2 class="ph__cta-title">Smetti di improvvisare.<br />Inizia con un metodo.</h2>
              <p class="ph__cta-text">Programmi strutturati, progressioni settimanali e nutrizione inclusa. Sai sempre cosa fare.</p>
              <a
                href="https://web.cottoaldente.it/?_gl=1*1rigkb2*_gcl_au*OTgxMjEwNTI2LjE3NjM3MTUwODk.#/signup"
                target="_blank"
                rel="noopener"
                class="btn btn-primary"
              >
                Inizia ora
              </a>
              <ul class="ph__cta-checks" role="list">
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Accesso immediato
                </li>
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Cancelli quando vuoi
                </li>
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Live workout inclusi
                </li>
              </ul>
            </div>
          </aside>

        </div>
      </div>
    </section>

    <!-- Leggi anche — stesso stile grid del blog index -->
    {otherPosts.length > 0 && (
      <section class="ph__more">
        <div class="container">
          <div class="ph__more-header">
            <p class="ph__more-eyebrow">Continua a leggere</p>
            <h2 class="ph__more-title">Leggi anche</h2>
          </div>
          <div class="ph__more-grid">
            {otherPosts.map((p) => (
              <article class="ph__more-card">
                <a href={`/blog/${p.slug}`} class="ph__more-link">
                  <div class="ph__more-cover">
                    <img src={p.cover} alt={p.title} loading="lazy" width="600" height="340" />
                  </div>
                  <div class="ph__more-body">
                    <div class="ph__more-meta">
                      <span class="ph__more-cat">{p.category}</span>
                      <span class="ph__more-sep">·</span>
                      <span class="ph__more-read">{p.readTime} di lettura</span>
                    </div>
                    <h3 class="ph__more-h">{p.title}</h3>
                    <p class="ph__more-excerpt">{p.excerpt}</p>
                    <span class="ph__more-arrow">Leggi →</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .ph__hero {
    position: relative;
    height: clamp(340px, 52vh, 540px);
    margin-top: var(--header-h, 104px);
    overflow: hidden;
  }

  .ph__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .ph__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0,0,0,0.25) 0%,
      rgba(0,0,0,0.65) 100%
    );
  }

  .ph__hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding-bottom: 48px;
  }

  .ph__meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  .ph__back {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ph__back:hover {
    color: #ffffff;
  }

  .ph__category {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    background: rgba(232,82,26,0.18);
    padding: 4px 12px;
    border-radius: 100px;
  }

  .ph__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(26px, 4.5vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: #ffffff;
    margin: 0 0 16px;
    max-width: 760px;
  }

  .ph__info {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: rgba(255,255,255,0.55);
  }

  /* ── Layout corpo ── */
  .ph__body-section {
    background: #ffffff;
    padding: 64px 0 80px;
  }

  .ph__layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 56px;
    align-items: start;
  }

  /* ── Testo articolo ── */
  .ph__content {
    font-size: 17px;
    line-height: 1.8;
    color: var(--gray-600);
    max-width: 680px;
  }

  .ph__content :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(20px, 2.5vw, 28px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 48px 0 16px;
  }

  .ph__content :global(h2:first-child) {
    margin-top: 0;
  }

  .ph__content :global(p) {
    margin: 0 0 20px;
  }

  .ph__content :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ph__content :global(li) {
    padding-left: 22px;
    position: relative;
    color: var(--gray-600);
  }

  .ph__content :global(li::before) {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--orange);
    font-weight: 700;
  }

  .ph__content :global(strong) {
    color: var(--white);
    font-weight: 600;
  }

  /* ── Sidebar ── */
  .ph__sidebar {
    position: sticky;
    top: calc(var(--header-h, 104px) + 24px);
  }

  /* Stessa card scura usata nelle pricing / HowItWorks */
  .ph__cta-card {
    background: #111111;
    border-radius: 24px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ph__cta-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    margin: 0;
  }

  .ph__cta-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0;
  }

  .ph__cta-text {
    font-size: 14px;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin: 0;
  }

  /* btn btn-primary già definito nel global.css */
  .ph__cta-card .btn {
    justify-content: center;
  }

  .ph__cta-checks {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ph__cta-checks li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.6);
  }

  .ph__cta-checks svg {
    color: var(--orange);
    flex-shrink: 0;
  }

  /* ── Leggi anche ── */
  .ph__more {
    background: #f5f2ee;
    padding: var(--section-py) 0;
    border-top: 1px solid rgba(17,17,17,0.08);
  }

  .ph__more-header {
    margin-bottom: 40px;
  }

  .ph__more-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 10px;
  }

  .ph__more-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 3.5vw, 40px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--white);
    margin: 0;
  }

  .ph__more-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .ph__more-card {
    background: #ffffff;
    border-radius: 24px;
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .ph__more-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 56px rgba(0,0,0,0.09);
  }

  .ph__more-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ph__more-cover {
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .ph__more-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .ph__more-card:hover .ph__more-cover img {
    transform: scale(1.04);
  }

  .ph__more-body {
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .ph__more-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ph__more-cat {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .ph__more-sep {
    color: var(--gray-300);
  }

  .ph__more-read {
    font-size: 12px;
    color: var(--gray-400);
  }

  .ph__more-h {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--white);
    margin: 0;
  }

  .ph__more-excerpt {
    font-size: 13px;
    color: var(--gray-500);
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ph__more-arrow {
    font-size: 13px;
    font-weight: 700;
    color: var(--orange);
    margin-top: auto;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .ph__layout {
      grid-template-columns: 1fr;
    }

    .ph__sidebar {
      position: static;
    }
  }

  @media (max-width: 600px) {
    .ph__body-section {
      padding: 40px 0 56px;
    }

    .ph__more-grid {
      grid-template-columns: 1fr;
    }

    .ph__more {
      padding: 56px 0;
    }
  }
</style>

<script>
  function setHeaderHeight() {
    const header = document.querySelector('header');
    if (header) {
      document.documentElement.style.setProperty('--header-h', header.getBoundingClientRect().height + 'px');
    }
  }
  setHeaderHeight();
  window.addEventListener('resize', setHeaderHeight);
</script>
