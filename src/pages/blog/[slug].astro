---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { posts } from '../../data/posts';

export function getStaticPaths() {
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = posts.find((p) => p.slug === slug);
if (!post) return Astro.redirect('/blog');

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
}

const otherPosts = posts.filter((p) => p.slug !== slug).slice(0, 2);
---

<Layout
  title={`${post.title} – HEAT Blog`}
  description={post.excerpt}
  image={post.cover}
  canonical={`https://www.heatfitness.app/blog/${post.slug}`}
>
  <Header />

  <main>
    <div class="ph-hero">
      <picture>
        <img
          src={post.cover}
          alt={post.title}
          class="ph-hero__img"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          width="1200"
          height="600"
        />
      </picture>
      <div class="ph-hero__overlay"></div>
      <div class="ph-hero__content">
        <div class="ph-container">
          <div class="ph-hero__meta">
            <a href="/blog" class="ph-hero__back">← Blog</a>
            <span class="ph-hero__cat">{post.category}</span>
          </div>
          <h1 class="ph-hero__title">{post.title}</h1>
          <div class="ph-hero__info">
            <time datetime={post.date}>{formatDate(post.date)}</time>
            <span aria-hidden="true">·</span>
            <span>{post.readTime} di lettura</span>
          </div>
        </div>
      </div>
    </div>

    <section class="ph-body">
      <div class="ph-container">
        <div class="ph-layout">
          <article class="ph-article" set:html={post.content} />

          <aside class="ph-sidebar">
            <div class="ph-cta-card">
              <p class="ph-cta-card__eyebrow">Il metodo HEAT</p>
              <h2 class="ph-cta-card__title">Smetti di improvvisare.<br />Inizia con un metodo.</h2>
              <p class="ph-cta-card__text">Programmi strutturati, progressioni settimanali e nutrizione inclusa. Sai sempre cosa fare.</p>
              <a
                href="https://web.cottoaldente.it/?_gl=1*1rigkb2*_gcl_au*OTgxMjEwNTI2LjE3NjM3MTUwODk.#/signup"
                target="_blank"
                rel="noopener"
                class="ph-btn"
              >
                Inizia ora
              </a>
              <ul class="ph-cta-card__checks" role="list">
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Accesso immediato
                </li>
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Cancelli quando vuoi
                </li>
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Live workout inclusi
                </li>
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </section>

    {otherPosts.length > 0 && (
      <section class="ph-more">
        <div class="ph-container">
          <div class="ph-more__header">
            <p class="ph-more__eyebrow">Continua a leggere</p>
            <h2 class="ph-more__title">Leggi anche</h2>
          </div>
          <div class="ph-more__grid">
            {otherPosts.map((p) => (
              <article class="ph-more__card">
                <a href={`/blog/${p.slug}`} class="ph-more__link">
                  <div class="ph-more__cover">
                    <img src={p.cover} alt={p.title} loading="lazy" width="600" height="340" />
                  </div>
                  <div class="ph-more__body">
                    <div class="ph-more__meta">
                      <span class="ph-more__cat">{p.category}</span>
                      <span class="ph-more__sep">·</span>
                      <span class="ph-more__read">{p.readTime} di lettura</span>
                    </div>
                    <h3 class="ph-more__h">{p.title}</h3>
                    <p class="ph-more__excerpt">{p.excerpt}</p>
                    <span class="ph-more__arrow">Leggi →</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<style>
  .ph-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Hero ── */
  .ph-hero {
    position: relative;
    height: clamp(340px, 52vh, 540px);
    margin-top: var(--header-h, 104px);
    overflow: hidden;
  }

  .ph-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .ph-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.65) 100%);
  }

  .ph-hero__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding-bottom: 48px;
  }

  .ph-hero__meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  .ph-hero__back {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ph-hero__back:hover { color: #ffffff; }

  .ph-hero__cat {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    background: rgba(232,82,26,0.18);
    padding: 4px 12px;
    border-radius: 100px;
  }

  .ph-hero__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(26px, 4.5vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: #ffffff;
    margin: 0 0 16px;
    max-width: 760px;
  }

  .ph-hero__info {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: rgba(255,255,255,0.55);
  }

  /* ── Body ── */
  .ph-body {
    background: #ffffff;
    padding: 64px 0 80px;
  }

  .ph-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 56px;
    align-items: start;
  }

  /* ── Article content ── */
  .ph-article {
    font-size: 17px;
    line-height: 1.8;
    color: var(--gray-600);
    max-width: 680px;
  }

  .ph-article :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(20px, 2.5vw, 28px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 48px 0 16px;
  }

  .ph-article :global(h2:first-child) { margin-top: 0; }

  .ph-article :global(p) { margin: 0 0 20px; }

  .ph-article :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ph-article :global(li) {
    padding-left: 22px;
    position: relative;
    color: var(--gray-600);
  }

  .ph-article :global(li::before) {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--orange);
    font-weight: 700;
  }

  .ph-article :global(strong) {
    color: var(--white);
    font-weight: 600;
  }

  /* ── Sidebar ── */
  .ph-sidebar {
    position: sticky;
    top: calc(var(--header-h, 104px) + 24px);
  }

  .ph-cta-card {
    background: #111111;
    border-radius: 24px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ph-cta-card__eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    margin: 0;
  }

  .ph-cta-card__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0;
  }

  .ph-cta-card__text {
    font-size: 14px;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin: 0;
  }

  .ph-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
    background: var(--orange);
    color: #ffffff;
    text-decoration: none;
    cursor: pointer;
    border: none;
    width: 100%;
    box-sizing: border-box;
    transition: background 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ph-btn:hover {
    background: var(--orange-dark);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(232, 82, 26, 0.35);
  }

  .ph-cta-card__checks {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ph-cta-card__checks li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.6);
  }

  .ph-cta-card__checks svg {
    color: var(--orange);
    flex-shrink: 0;
  }

  /* ── Leggi anche ── */
  .ph-more {
    background: var(--gray-100);
    padding: 100px 0;
    border-top: 1px solid rgba(17,17,17,0.08);
  }

  .ph-more__header { margin-bottom: 40px; }

  .ph-more__eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 10px;
  }

  .ph-more__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 3.5vw, 40px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--white);
    margin: 0;
  }

  .ph-more__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .ph-more__card {
    background: #ffffff;
    border-radius: 24px;
    overflow: hidden;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ph-more__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 56px rgba(0,0,0,0.09);
  }

  .ph-more__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ph-more__cover {
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .ph-more__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .ph-more__card:hover .ph-more__cover img {
    transform: scale(1.04);
  }

  .ph-more__body {
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .ph-more__meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ph-more__cat {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .ph-more__sep { color: var(--gray-300); }
  .ph-more__read { font-size: 12px; color: var(--gray-400); }

  .ph-more__h {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--white);
    margin: 0;
  }

  .ph-more__excerpt {
    font-size: 13px;
    color: var(--gray-500);
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ph-more__arrow {
    font-size: 13px;
    font-weight: 700;
    color: var(--orange);
    margin-top: auto;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .ph-layout { grid-template-columns: 1fr; }
    .ph-sidebar { position: static; }
  }

  @media (max-width: 600px) {
    .ph-body { padding: 40px 0 56px; }
    .ph-more__grid { grid-template-columns: 1fr; }
    .ph-more { padding: 56px 0; }
  }
</style>

<script>
  function setHeaderHeight() {
    const header = document.querySelector('header');
    if (header) {
      document.documentElement.style.setProperty('--header-h', header.getBoundingClientRect().height + 'px');
    }
  }
  setHeaderHeight();
  window.addEventListener('resize', setHeaderHeight);
</script>
