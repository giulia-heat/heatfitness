---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { posts } from '../../data/posts';
import '../../styles/global.css';

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout
  title="Blog – HEAT Fitness"
  description="Articoli su allenamento, nutrizione e mindset per chi vuole risultati veri. Dal team HEAT Fitness."
  canonical="https://www.heatfitness.app/blog"
>
  <Header />

  <main>
    <section class="bi-hero">
      <div class="bi-container">
        <div class="bi-hero__inner" data-animate>
          <p class="bi-eyebrow">Blog</p>
          <h1 class="bi-hero__title">Metodo, nutrizione<br />e mindset.</h1>
          <p class="bi-hero__sub">Tutto quello che ti serve per allenarti meglio, mangiare meglio e restare costante nel tempo.</p>
        </div>
      </div>
    </section>

    <section class="bi-grid-section">
      <div class="bi-container">
        <div class="bi-grid">
          {posts.slice(0, 1).map((post) => (
            <article class="bi-card bi-card--feat" data-animate>
              <a href={`/blog/${post.slug}`} class="bi-card__link">
                <div class="bi-card__cover bi-card__cover--feat">
                  <img src={post.cover} alt={post.title} loading="eager" width="800" height="500" />
                </div>
                <div class="bi-card__body bi-card__body--feat">
                  <div class="bi-card__meta">
                    <span class="bi-card__cat">{post.category}</span>
                    <span class="bi-card__sep">·</span>
                    <span class="bi-card__read">{post.readTime} di lettura</span>
                  </div>
                  <h2 class="bi-card__title">{post.title}</h2>
                  <p class="bi-card__excerpt">{post.excerpt}</p>
                  <div class="bi-card__foot">
                    <time class="bi-card__date" datetime={post.date}>{formatDate(post.date)}</time>
                    <span class="bi-card__arrow">Leggi →</span>
                  </div>
                </div>
              </a>
            </article>
          ))}

          {posts.slice(1).map((post, i) => (
            <article class="bi-card" data-animate data-delay={String(i + 1)}>
              <a href={`/blog/${post.slug}`} class="bi-card__link">
                <div class="bi-card__cover bi-card__cover--ratio">
                  <img src={post.cover} alt={post.title} loading="lazy" width="600" height="340" />
                </div>
                <div class="bi-card__body">
                  <div class="bi-card__meta">
                    <span class="bi-card__cat">{post.category}</span>
                    <span class="bi-card__sep">·</span>
                    <span class="bi-card__read">{post.readTime} di lettura</span>
                  </div>
                  <h2 class="bi-card__title bi-card__title--sm">{post.title}</h2>
                  <p class="bi-card__excerpt">{post.excerpt}</p>
                  <div class="bi-card__foot">
                    <time class="bi-card__date" datetime={post.date}>{formatDate(post.date)}</time>
                    <span class="bi-card__arrow">Leggi →</span>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .bi-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .bi-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 20px;
  }

  .bi-hero {
    background: #ffffff;
    padding-top: var(--header-h, 104px);
  }

  .bi-hero__inner {
    padding: 72px 0 64px;
    max-width: 680px;
  }

  .bi-hero__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 0.97;
    letter-spacing: -0.03em;
    color: var(--white);
    margin: 0 0 20px;
  }

  .bi-hero__sub {
    font-size: 17px;
    color: var(--gray-500);
    line-height: 1.7;
    max-width: 480px;
    margin: 0;
  }

  .bi-grid-section {
    background: var(--gray-100);
    padding: 56px 0 80px;
    border-top: 1px solid rgba(17,17,17,0.08);
  }

  .bi-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .bi-card--feat {
    grid-column: 1 / -1;
  }

  .bi-card {
    background: #ffffff;
    border-radius: 24px;
    overflow: hidden;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .bi-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 56px rgba(0,0,0,0.09);
  }

  .bi-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .bi-card--feat .bi-card__link {
    flex-direction: row;
  }

  .bi-card__cover {
    overflow: hidden;
    flex-shrink: 0;
  }

  .bi-card__cover--feat {
    width: 52%;
  }

  .bi-card__cover--ratio {
    aspect-ratio: 16 / 9;
  }

  .bi-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .bi-card:hover .bi-card__cover img {
    transform: scale(1.04);
  }

  .bi-card__body {
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .bi-card__body--feat {
    padding: 40px 48px;
    justify-content: center;
  }

  .bi-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bi-card__cat {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .bi-card__sep { color: var(--gray-300); font-size: 14px; }

  .bi-card__read {
    font-size: 12px;
    color: var(--gray-400);
    font-weight: 500;
  }

  .bi-card__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(20px, 2.2vw, 30px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 0;
  }

  .bi-card__title--sm { font-size: clamp(18px, 1.8vw, 22px); }

  .bi-card__excerpt {
    font-size: 14px;
    color: var(--gray-500);
    line-height: 1.7;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bi-card__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--gray-200);
  }

  .bi-card__date { font-size: 12px; color: var(--gray-400); }

  .bi-card__arrow {
    font-size: 13px;
    font-weight: 700;
    color: var(--orange);
    letter-spacing: 0.01em;
  }

  @media (max-width: 768px) {
    .bi-hero__inner { padding: 48px 0 40px; }
    .bi-grid { grid-template-columns: 1fr; }
    .bi-card--feat { grid-column: auto; }
    .bi-card--feat .bi-card__link { flex-direction: column; }
    .bi-card__cover--feat { width: 100%; aspect-ratio: 16 / 9; }
    .bi-card__body--feat { padding: 24px; }
  }
</style>

<script>
  function setHeaderHeight() {
    const header = document.querySelector('header');
    if (header) {
      document.documentElement.style.setProperty('--header-h', header.getBoundingClientRect().height + 'px');
    }
  }
  setHeaderHeight();
  window.addEventListener('resize', setHeaderHeight);

  const animateElements = document.querySelectorAll<HTMLElement>('[data-animate]');
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );
    animateElements.forEach((el) => observer.observe(el));
  } else {
    animateElements.forEach((el) => el.classList.add('is-visible'));
  }
</script>
